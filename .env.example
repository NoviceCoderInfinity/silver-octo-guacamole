ANTHROPIC_API_KEY=paste-your-anthropic-api-key-here
# Optional — defaults to claude-sonnet-5 if unset:
# CLAUDE_MODEL_ID=claude-sonnet-5

# Optional Gemini video-native describe front-end (style writing stays on Claude):
# GEMINI_API_KEY=...
# DESCRIBE_BACKEND=gemini
# GEMINI_MODEL_ID=gemini-3-flash-preview
FRAME_SAMPLE_MODE=scene
# ENABLE_CRITIQUE_REPAIR=false

# Optional judge/dev settings. Fireworks can still be used as an independent scorer.
# FIREWORKS_API_KEY=fw_...
# FIREWORKS_MODEL_ID=accounts/fireworks/models/qwen3p7-plus
# JUDGE_PROVIDER=fireworks
# JUDGE_MODEL_ID=accounts/fireworks/models/qwen3p7-plus
